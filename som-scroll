#!/usr/bin/env python3
"""
som-scroll: 页面滚动 + 自动截图标注

用法:
    som-scroll down                  # 向下滚动一页 (Page Down)
    som-scroll down --lines 1        # 向下滚动 100px（约 1 个 SKU 选项高度）
    som-scroll down --lines 3        # 向下滚动 300px（精细滚动，适合 SKU 区域）
    som-scroll up --lines 2          # 向上滚动 200px
    som-scroll top                   # 回到顶部
    som-scroll bottom                # 到底部
    som-scroll down --annotate       # 滚动后自动标注
    som-scroll down -n 3 --collect   # 滚动 3 次，合并所有视口元素
"""
import argparse
import json
import os
import subprocess
import sys
import time

import pyautogui

pyautogui.FAILSAFE = False
pyautogui.PAUSE = 0.05

PIXELS_PER_LINE = 100  # 1 line = 100 logical pixels

# pyautogui.scroll(n): 1 unit ≈ ~45px (varies by OS/browser, tested on Linux)
PIXELS_PER_SCROLL_UNIT = 45


def scroll(direction, count=1, lines=0):
    """Scroll the page.

    lines=0 (default): page scroll (Page_Down/Page_Up via keypress)
    lines=N: fine scroll by N * 100px using mouse wheel.
    """
    if direction in ("top", "bottom"):
        pyautogui.press("home" if direction == "top" else "end")
        time.sleep(0.5)
        return

    if lines > 0:
        # Fine scroll: convert pixels to scroll units
        pixels = lines * PIXELS_PER_LINE
        units = max(1, pixels // PIXELS_PER_SCROLL_UNIT)
        sign = -1 if direction == "down" else 1
        for _ in range(count):
            pyautogui.scroll(sign * units)
            time.sleep(0.3)
    else:
        # Full page scroll via keyboard
        key = "pagedown" if direction == "down" else "pageup"
        for _ in range(count):
            pyautogui.press(key)
            time.sleep(0.5)


def annotate(output_prefix, json_path):
    """Call som-annotate (which handles server detection internally)."""
    script_dir = os.path.dirname(os.path.abspath(__file__))
    annotate_script = os.path.join(script_dir, "som-annotate")
    result = subprocess.run(
        [sys.executable, annotate_script, "-o", output_prefix + ".png", "-j", json_path, "-q"],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        print(f"Annotation failed: {result.stderr}", file=sys.stderr)
        return None
    return json_path


def merge_elements(all_elements_files):
    """Merge elements from multiple viewport captures, deduplicating by position."""
    sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
    from som_common import load_elements

    all_elements = []
    seen = set()

    for fpath in all_elements_files:
        elements, _meta = load_elements(fpath)
        for e in elements:
            key = (e["center_x"] // 30, e["center_y"] // 30, e.get("content", "")[:20])
            if key not in seen:
                seen.add(key)
                all_elements.append(e)

    for i, e in enumerate(all_elements):
        e["index"] = i

    return all_elements


def main():
    ap = argparse.ArgumentParser(description="Scroll and optionally annotate")
    ap.add_argument("direction", choices=["down", "up", "top", "bottom"])
    ap.add_argument("-n", "--count", type=int, default=1, help="Number of scrolls")
    ap.add_argument("-l", "--lines", type=int, default=0,
                    help="Fine scroll N lines (1 line=100px). 0=page scroll. 1≈one SKU row, 3≈300px.")
    ap.add_argument("--annotate", "-a", action="store_true", help="Annotate after scrolling")
    ap.add_argument("--collect", "-c", action="store_true", help="Scroll N times, annotate each, merge results")
    ap.add_argument("--output", "-o", default="som_scrolled", help="Output prefix")
    ap.add_argument("--json", "-j", default="som_elements.json", help="Elements JSON path")
    args = ap.parse_args()

    if args.collect:
        temp_files = []
        for i in range(args.count):
            if i > 0:
                scroll(args.direction, 1, lines=args.lines)
                time.sleep(1)

            temp_json = f"/tmp/som_viewport_{i}.json"
            temp_prefix = f"/tmp/som_viewport_{i}"
            print(f"Viewport {i+1}/{args.count}...", file=sys.stderr)
            annotate(temp_prefix, temp_json)
            temp_files.append(temp_json)

        merged = merge_elements(temp_files)
        with open(args.json, "w") as f:
            json.dump(merged, f, ensure_ascii=False, indent=2)
        print(f"Merged {len(merged)} unique elements from {args.count} viewports", file=sys.stderr)

    else:
        scroll(args.direction, args.count, lines=args.lines)
        mode = f"{args.lines} lines" if args.lines > 0 else "page"
        print(f"Scrolled {args.direction} x{args.count} ({mode})", file=sys.stderr)

        if args.annotate:
            time.sleep(1)
            annotate(args.output, args.json)

    return 0


if __name__ == "__main__":
    sys.exit(main())
