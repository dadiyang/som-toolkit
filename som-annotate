#!/usr/bin/env python3
"""
som-annotate: 截图 + OmniParser 标注 + 输出元素列表
用法:
    som-annotate                     # 标注全屏
    som-annotate --output result.png # 指定输出
    som-annotate --json elements.json
"""
import argparse
import base64
import io
import json
import os
import platform
import subprocess
import sys
import time

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))


def find_omniparser():
    """Search for OmniParser in standard locations."""
    candidates = [
        os.path.join(SCRIPT_DIR, "omniparser"),           # symlink/subdir
        os.path.join(SCRIPT_DIR, "..", "OmniParser"),      # sibling dir
        os.path.join(os.path.expanduser("~"), "OmniParser"),  # home dir
        os.environ.get("OMNIPARSER_DIR", ""),              # env var
    ]
    for path in candidates:
        if path and os.path.isfile(os.path.join(path, "util", "omniparser.py")):
            return path
    sys.exit(
        "ERROR: OmniParser not found.\n"
        "Run install.sh, or set OMNIPARSER_DIR, or create a symlink:\n"
        f"  ln -s /path/to/OmniParser {os.path.join(SCRIPT_DIR, 'omniparser')}"
    )


OMNI_DIR = find_omniparser()

# ─── 截图 ───────────────────────────────────────────────
def take_screenshot(output_path):
    """Take a fresh screenshot. Deletes existing file first to avoid stale data."""
    # Remove existing file to guarantee freshness
    if os.path.exists(output_path):
        os.remove(output_path)

    system = platform.system()
    if system == "Darwin":
        subprocess.run(["screencapture", "-x", output_path], check=True)
    elif system == "Linux":
        display = os.environ.get("DISPLAY")
        if not display:
            for d in [":10.0", ":0"]:
                try:
                    subprocess.run(["xdotool", "getdisplaygeometry"],
                                   env={**os.environ, "DISPLAY": d},
                                   capture_output=True, check=True)
                    os.environ["DISPLAY"] = d
                    break
                except (subprocess.CalledProcessError, FileNotFoundError):
                    continue
        subprocess.run(["scrot", output_path], check=True)

    # Verify screenshot was actually created
    if not os.path.exists(output_path):
        sys.exit(f"ERROR: Screenshot failed. File not created: {output_path}")
    else:
        raise RuntimeError(f"Unsupported platform: {system}")


def get_screen_size():
    system = platform.system()
    if system == "Darwin":
        out = subprocess.check_output([
            "python3", "-c",
            "import AppKit; s=AppKit.NSScreen.mainScreen().frame().size; print(int(s.width), int(s.height))"
        ]).decode().strip().split()
        return int(out[0]), int(out[1])
    elif system == "Linux":
        out = subprocess.check_output(["xdotool", "getdisplaygeometry"]).decode().strip().split()
        return int(out[0]), int(out[1])
    return 1920, 1080


# ─── OmniParser ────────────────────────────────────────
def load_parser():
    sys.path.insert(0, OMNI_DIR)
    os.environ.setdefault("PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK", "True")

    from util.omniparser import Omniparser

    weights_dir = os.path.join(OMNI_DIR, "weights")
    config = {
        "som_model_path": os.path.join(weights_dir, "icon_detect", "model.pt"),
        "caption_model_name": "florence2",
        "caption_model_path": os.path.join(weights_dir, "icon_caption_florence"),
        "BOX_TRESHOLD": 0.05,
    }
    return Omniparser(config)


def parse_screenshot(parser, image_path, screen_w, screen_h):
    from PIL import Image

    img = Image.open(image_path)
    orig_w, orig_h = img.size

    # Resize if too large (saves memory and time)
    MAX_W = 1920
    if img.width > MAX_W:
        ratio = MAX_W / img.width
        img = img.resize((MAX_W, int(img.height * ratio)), Image.LANCZOS)

    buf = io.BytesIO()
    img.save(buf, format="PNG")
    img_b64 = base64.b64encode(buf.getvalue()).decode()

    labeled_b64, parsed_content = parser.parse(img_b64)

    # Convert bbox ratios to screen coordinates
    elements = []
    for idx, item in enumerate(parsed_content):
        bbox = item["bbox"]  # [x1_ratio, y1_ratio, x2_ratio, y2_ratio]
        cx = int((bbox[0] + bbox[2]) / 2 * screen_w)
        cy = int((bbox[1] + bbox[3]) / 2 * screen_h)
        w = int((bbox[2] - bbox[0]) * screen_w)
        h = int((bbox[3] - bbox[1]) * screen_h)

        elements.append({
            "index": idx,
            "type": item.get("type", ""),
            "content": item.get("content", ""),
            "interactivity": item.get("interactivity", False),
            "center_x": cx,
            "center_y": cy,
            "width": w,
            "height": h,
            "bbox_ratio": bbox,
        })

    return labeled_b64, elements


# ─── Server Client ─────────────────────────────────────
def try_server(image_path, screen_w, screen_h, quiet=False):
    """Try to use som-server for fast parsing. Returns None if server not available."""
    try:
        import urllib.request
        # Health check
        resp = urllib.request.urlopen("http://127.0.0.1:8765/health", timeout=2)
        if resp.read() != b"ok":
            return None
    except Exception:
        return None

    if not quiet:
        print("Using som-server (fast mode)...", file=sys.stderr)

    from PIL import Image as PILImage

    img = PILImage.open(image_path)
    MAX_W = 1920
    if img.width > MAX_W:
        ratio = MAX_W / img.width
        img = img.resize((MAX_W, int(img.height * ratio)), PILImage.LANCZOS)

    buf = io.BytesIO()
    img.save(buf, format="PNG")
    img_b64 = base64.b64encode(buf.getvalue()).decode()

    req_data = json.dumps({
        "image_base64": img_b64,
        "screen_w": screen_w,
        "screen_h": screen_h,
    }).encode()

    req = urllib.request.Request(
        "http://127.0.0.1:8765/parse",
        data=req_data,
        headers={"Content-Type": "application/json"}
    )
    resp = urllib.request.urlopen(req, timeout=300)
    result = json.loads(resp.read())

    return result["labeled_image_base64"], result["elements"]


# ─── Main ──────────────────────────────────────────────
def main():
    ap = argparse.ArgumentParser(description="SoM screen annotator")
    ap.add_argument("--output", "-o", default="som_annotated.png", help="Annotated screenshot path")
    ap.add_argument("--json", "-j", default="som_elements.json", help="Elements JSON path")
    ap.add_argument("--screenshot", "-s", help="Use existing screenshot instead of capturing")
    ap.add_argument("--quiet", "-q", action="store_true", help="Minimal output")
    ap.add_argument("--wait", "-w", type=float, default=1.0, help="Wait seconds before screenshot (default 1.0)")
    args = ap.parse_args()

    screen_w, screen_h = get_screen_size()
    if not args.quiet:
        print(f"Screen: {screen_w}x{screen_h}", file=sys.stderr)

    # Screenshot
    raw_path = args.screenshot or "/tmp/som_raw_screenshot.png"
    if not args.screenshot:
        if args.wait > 0:
            time.sleep(args.wait)
        if not args.quiet:
            print("Taking screenshot...", file=sys.stderr)
        take_screenshot(raw_path)

    # Parse - try server first (fast), fallback to direct load (slow)
    t0 = time.time()
    server_result = try_server(raw_path, screen_w, screen_h, quiet=args.quiet)

    if server_result:
        labeled_b64, elements = server_result
    else:
        if not args.quiet:
            print("Loading OmniParser (no server, will be slow)...", file=sys.stderr)
            print("TIP: Run 'som-server start' to keep the model loaded.", file=sys.stderr)
        parser = load_parser()
        if not args.quiet:
            print("Detecting elements...", file=sys.stderr)
        labeled_b64, elements = parse_screenshot(parser, raw_path, screen_w, screen_h)

    elapsed = time.time() - t0

    # Save annotated image
    from PIL import Image
    labeled_img = Image.open(io.BytesIO(base64.b64decode(labeled_b64)))
    labeled_img.save(args.output)

    # Save elements JSON
    with open(args.json, "w", encoding="utf-8") as f:
        json.dump(elements, f, ensure_ascii=False, indent=2)

    if not args.quiet:
        print(f"Detected {len(elements)} elements in {elapsed:.1f}s", file=sys.stderr)
        print(f"Annotated: {args.output}", file=sys.stderr)
        print(f"Elements:  {args.json}", file=sys.stderr)

    # Print element summary to stdout (for piping to agent)
    for e in elements:
        content = e["content"].strip()
        if content:
            print(f'[{e["index"]}] ({e["center_x"]},{e["center_y"]}) {e["type"]} "{content}"')

    return 0


if __name__ == "__main__":
    sys.exit(main())
