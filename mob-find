#!/usr/bin/env python3
"""
mob-find: 搜索 Android UI 元素

用法:
    mob-find "购买"                       # 按文字搜索
    mob-find "购买" --first --cmd         # 输出 mob-click 命令
    mob-find --clickable                  # 只看可点击元素
    mob-find --summary                    # 页面概览
    mob-find --extract                    # 提取结构化信息（价格/按钮等）
"""
import argparse
import json
import os
import sys

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, SCRIPT_DIR)


def load_elements(json_path):
    if not os.path.exists(json_path):
        print(f"ERROR: {json_path} not found. Run mob-annotate first.", file=sys.stderr)
        sys.exit(1)
    with open(json_path) as f:
        return json.load(f)


def page_summary(elements):
    lines = ["=== Page Summary ==="]

    pkg = ""
    buttons = []
    texts = []
    inputs = []
    scrollables = []
    prices = []

    for e in elements:
        label = (e.get("label") or "").strip()
        text = (e.get("text") or "").strip()
        if not label and not text:
            continue

        display = label or text
        cl = e.get("class_name", "")

        if "¥" in display or "$" in display or "价" in display:
            prices.append(e)
        elif "EditText" in cl:
            inputs.append(e)
        elif e.get("scrollable"):
            scrollables.append(e)
        elif e.get("clickable"):
            buttons.append(e)
        elif text:
            texts.append(e)

    if prices:
        lines.append(f"\nPrices ({len(prices)}):")
        for e in prices:
            lines.append(f'  [{e["index"]}] {e.get("text") or e.get("label")}')

    if buttons:
        lines.append(f"\nClickable ({len(buttons)}):")
        for e in buttons[:20]:
            lines.append(f'  [{e["index"]}] {e.get("label") or e.get("text")}')

    if inputs:
        lines.append(f"\nInput fields ({len(inputs)}):")
        for e in inputs:
            lines.append(f'  [{e["index"]}] {e.get("text") or e.get("resource_id", "").split("/")[-1]}')

    if texts:
        lines.append(f"\nText ({len(texts)}):")
        for e in texts[:15]:
            lines.append(f'  [{e["index"]}] {e.get("text")}')

    total = len(elements)
    clickable = sum(1 for e in elements if e.get("clickable"))
    lines.append(f"\nTotal: {total} elements ({clickable} clickable)")
    return "\n".join(lines)


def extract_info(elements):
    info = {
        "prices": [],
        "buttons": [],
        "inputs": [],
        "texts": [],
    }
    for e in elements:
        text = (e.get("text") or "").strip()
        label = (e.get("label") or "").strip()
        display = text or label
        if not display:
            continue

        if "¥" in display or "$" in display or "价" in display:
            info["prices"].append({"index": e["index"], "text": display})
        elif e.get("clickable"):
            info["buttons"].append({"index": e["index"], "text": display})
        elif "EditText" in e.get("class_name", ""):
            info["inputs"].append({"index": e["index"], "text": display})
        else:
            info["texts"].append({"index": e["index"], "text": display})

    return info


def main():
    ap = argparse.ArgumentParser(description="Search Android UI elements")
    ap.add_argument("keyword", nargs="?", help="Keyword to search")
    ap.add_argument("-j", "--json", default="mob_elements.json")
    ap.add_argument("--clickable", "-c", action="store_true")
    ap.add_argument("--first", "-1", action="store_true")
    ap.add_argument("--summary", "-s", action="store_true")
    ap.add_argument("--extract", "-e", action="store_true")
    ap.add_argument("--cmd", action="store_true", help="Output mob-click command")
    args = ap.parse_args()

    elements = load_elements(args.json)

    if args.summary:
        print(page_summary(elements))
        return 0

    if args.extract:
        print(json.dumps(extract_info(elements), ensure_ascii=False, indent=2))
        return 0

    results = elements
    if args.keyword:
        kw = args.keyword.lower()
        results = [e for e in results
                   if kw in (e.get("text") or "").lower()
                   or kw in (e.get("content_desc") or "").lower()
                   or kw in (e.get("label") or "").lower()
                   or kw in (e.get("resource_id") or "").lower()]
    if args.clickable:
        results = [e for e in results if e.get("clickable")]

    if not results:
        print("No elements found.", file=sys.stderr)
        return 1

    if args.first:
        results = results[:1]

    for e in results:
        if args.cmd:
            print(f'mob-click {e["index"]}')
        else:
            label = e.get("label") or e.get("text") or ""
            inter = "clickable" if e.get("clickable") else "static"
            print(f'[{e["index"]}] ({e.get("center_x")},{e.get("center_y")}) {inter} "{label}"')

    return 0


if __name__ == "__main__":
    sys.exit(main())
