#!/usr/bin/env python3
"""
som-click: 根据 SoM 编号点击元素
用法:
    som-click 42                          # 点击编号 42 的元素
    som-click 42 --json som_elements.json # 指定元素文件
    som-click --xy 500,300                # 直接点击坐标
"""
import argparse
import json
import os
import platform
import subprocess
import sys
import time


_cliclick_cache = None

def _cliclick_available():
    """Check if cliclick is installed (macOS mouse control tool). Cached."""
    global _cliclick_cache
    if _cliclick_cache is None:
        try:
            subprocess.run(["cliclick", "-V"], capture_output=True, check=True)
            _cliclick_cache = True
        except (FileNotFoundError, subprocess.CalledProcessError):
            _cliclick_cache = False
    return _cliclick_cache


def click_at(x, y):
    system = platform.system()
    if system == "Darwin":
        if _cliclick_available():
            subprocess.run(["cliclick", f"c:{x},{y}"], check=True)
        else:
            # Fallback: use python to generate CGEvent (requires pyobjc)
            subprocess.run([sys.executable, "-c", f"""
import Quartz
event = Quartz.CGEventCreateMouseEvent(None, Quartz.kCGEventMouseMoved, ({x}, {y}), Quartz.kCGMouseButtonLeft)
Quartz.CGEventPost(Quartz.kCGHIDEventTap, event)
import time; time.sleep(0.05)
event = Quartz.CGEventCreateMouseEvent(None, Quartz.kCGEventLeftMouseDown, ({x}, {y}), Quartz.kCGMouseButtonLeft)
Quartz.CGEventPost(Quartz.kCGHIDEventTap, event)
time.sleep(0.05)
event = Quartz.CGEventCreateMouseEvent(None, Quartz.kCGEventLeftMouseUp, ({x}, {y}), Quartz.kCGMouseButtonLeft)
Quartz.CGEventPost(Quartz.kCGHIDEventTap, event)
"""], check=True)
    elif system == "Linux":
        subprocess.run(["xdotool", "mousemove", str(x), str(y)], check=True)
        time.sleep(0.1)
        subprocess.run(["xdotool", "click", "1"], check=True)
    else:
        raise RuntimeError(f"Unsupported platform: {system}")


def double_click_at(x, y):
    system = platform.system()
    if system == "Darwin":
        if _cliclick_available():
            subprocess.run(["cliclick", f"dc:{x},{y}"], check=True)
        else:
            click_at(x, y)
            time.sleep(0.05)
            click_at(x, y)
    elif system == "Linux":
        subprocess.run(["xdotool", "mousemove", str(x), str(y)], check=True)
        time.sleep(0.1)
        subprocess.run(["xdotool", "click", "--repeat", "2", "--delay", "50", "1"], check=True)


def right_click_at(x, y):
    system = platform.system()
    if system == "Darwin":
        if _cliclick_available():
            subprocess.run(["cliclick", f"rc:{x},{y}"], check=True)
        else:
            subprocess.run([sys.executable, "-c", f"""
import Quartz
event = Quartz.CGEventCreateMouseEvent(None, Quartz.kCGEventMouseMoved, ({x}, {y}), Quartz.kCGMouseButtonRight)
Quartz.CGEventPost(Quartz.kCGHIDEventTap, event)
import time; time.sleep(0.05)
event = Quartz.CGEventCreateMouseEvent(None, Quartz.kCGEventRightMouseDown, ({x}, {y}), Quartz.kCGMouseButtonRight)
Quartz.CGEventPost(Quartz.kCGHIDEventTap, event)
time.sleep(0.05)
event = Quartz.CGEventCreateMouseEvent(None, Quartz.kCGEventRightMouseUp, ({x}, {y}), Quartz.kCGMouseButtonRight)
Quartz.CGEventPost(Quartz.kCGHIDEventTap, event)
"""], check=True)
    elif system == "Linux":
        subprocess.run(["xdotool", "mousemove", str(x), str(y)], check=True)
        time.sleep(0.1)
        subprocess.run(["xdotool", "click", "3"], check=True)


def main():
    ap = argparse.ArgumentParser(description="Click element by SoM index")
    ap.add_argument("index", nargs="?", type=int, help="Element index to click")
    ap.add_argument("--json", "-j", default="som_elements.json", help="Elements JSON path")
    ap.add_argument("--xy", help="Direct coordinates x,y")
    ap.add_argument("--double", action="store_true", help="Double click")
    ap.add_argument("--right", action="store_true", help="Right click")
    args = ap.parse_args()

    if args.xy:
        x, y = map(int, args.xy.split(","))
    elif args.index is not None:
        if not os.path.exists(args.json):
            print(f"ERROR: {args.json} not found. Run som-annotate first.", file=sys.stderr)
            return 1
        with open(args.json) as f:
            elements = json.load(f)
        matches = [e for e in elements if e["index"] == args.index]
        if not matches:
            print(f"ERROR: Element [{args.index}] not found. Max index: {max(e['index'] for e in elements)}", file=sys.stderr)
            return 1
        elem = matches[0]
        x, y = elem["center_x"], elem["center_y"]
        content = elem.get("content", "")
        print(f'Clicking [{args.index}] at ({x},{y}) "{content}"', file=sys.stderr)
    else:
        ap.print_help()
        return 1

    if args.double:
        double_click_at(x, y)
    elif args.right:
        right_click_at(x, y)
    else:
        click_at(x, y)

    print(f"OK ({x},{y})")
    return 0


if __name__ == "__main__":
    sys.exit(main())
