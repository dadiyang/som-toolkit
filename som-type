#!/usr/bin/env python3
"""
som-type: 点击元素后输入文字
用法:
    som-type 42 "hello world"             # 点击编号 42 然后输入
    som-type 42 "hello" --clear           # 先清空再输入
    som-type --xy 500,300 "hello"         # 直接坐标输入
    som-type --key Return                 # 按键
    som-type --key "ctrl+a"               # 组合键
"""
import argparse
import os
import platform
import subprocess
import sys
import time

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, SCRIPT_DIR)

from som_common import load_elements, parse_xy

import pyautogui
import pyperclip

pyautogui.FAILSAFE = False
pyautogui.PAUSE = 0.05

# Paste/select-all shortcut differs per platform
_PASTE_MOD = "command" if platform.system() == "Darwin" else "ctrl"
_SELECT_ALL_MOD = _PASTE_MOD


def click_at(x, y):
    """Delegate to som-click for consistent cross-platform behavior."""
    result = subprocess.run(
        [sys.executable, os.path.join(SCRIPT_DIR, "som-click"), "--xy", f"{x},{y}"],
        check=True, capture_output=True, text=True, timeout=10
    )
    if result.stderr:
        print(result.stderr, file=sys.stderr, end="")


def set_clipboard(text):
    pyperclip.copy(text)


def type_text(text):
    set_clipboard(text)
    time.sleep(0.1)
    pyautogui.hotkey(_PASTE_MOD, 'v')


def press_key(key_combo):
    """Press a key combination like 'ctrl+a' or 'Return'."""
    parts = key_combo.lower().split("+")
    if len(parts) == 1:
        key = parts[0]
        key_map = {"return": "enter", "escape": "esc", "delete": "backspace",
                   "page_down": "pagedown", "page_up": "pageup"}
        pyautogui.press(key_map.get(key, key))
    else:
        mod_map = {"cmd": "command" if platform.system() == "Darwin" else "ctrl",
                   "ctrl": "ctrl", "alt": "alt", "shift": "shift"}
        keys = [mod_map.get(k, k) for k in parts]
        pyautogui.hotkey(*keys)


def main():
    ap = argparse.ArgumentParser(description="Click element and type text")
    ap.add_argument("index", nargs="?", type=int, help="Element index")
    ap.add_argument("text", nargs="?", help="Text to type")
    ap.add_argument("--json", "-j", default="som_elements.json")
    ap.add_argument("--xy", help="Direct coordinates x,y")
    ap.add_argument("--clear", action="store_true", help="Clear field first (Ctrl+A)")
    ap.add_argument("--key", help="Press a key/combo instead of typing (e.g., Return, ctrl+a)")
    args = ap.parse_args()

    # Handle key-only mode
    if args.key and args.index is None and not args.xy:
        press_key(args.key)
        print(f"Key: {args.key}")
        return 0

    # Determine click target
    if args.xy:
        x, y = parse_xy(args.xy)
    elif args.index is not None:
        elements, _meta = load_elements(args.json)
        matches = [e for e in elements if e["index"] == args.index]
        if not matches:
            print(f"ERROR: Element [{args.index}] not found.", file=sys.stderr)
            return 1
        elem = matches[0]
        x, y = elem["center_x"], elem["center_y"]
    else:
        ap.print_help()
        return 1

    # Click
    click_at(x, y)
    time.sleep(0.3)

    # Clear if requested
    if args.clear:
        pyautogui.hotkey(_SELECT_ALL_MOD, 'a')
        time.sleep(0.1)

    # Type or press key
    if args.key:
        press_key(args.key)
        print(f"Key: {args.key} at ({x},{y})")
    elif args.text:
        type_text(args.text)
        print(f'Typed "{args.text}" at ({x},{y})')
    else:
        print(f"Clicked ({x},{y})")

    return 0


if __name__ == "__main__":
    sys.exit(main())
