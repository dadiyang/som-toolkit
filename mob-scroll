#!/usr/bin/env python3
"""
mob-scroll: Android 滚动操作

用法:
    mob-scroll down                      # 向下滚动半屏
    mob-scroll up                        # 向上滚动半屏
    mob-scroll down --pixels 200         # 精细滚动 200px
    mob-scroll down -n 3                 # 向下滚动 3 次
    mob-scroll left                      # 向左滑动（如切换 Tab）
    mob-scroll right                     # 向右滑动
"""
import argparse
import os
import sys

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, SCRIPT_DIR)

from mob_core import swipe, get_screen_size

DEFAULT_SCROLL_PX = 500  # 默认滚动像素


def main():
    ap = argparse.ArgumentParser(description="Android scroll/swipe")
    ap.add_argument("direction", choices=["down", "up", "left", "right"])
    ap.add_argument("-n", "--count", type=int, default=1)
    ap.add_argument("-p", "--pixels", type=int, default=DEFAULT_SCROLL_PX,
                    help=f"Scroll distance in pixels (default {DEFAULT_SCROLL_PX})")
    ap.add_argument("--slow", action="store_true", help="Slow scroll (800ms, more human-like)")
    args = ap.parse_args()

    w, h = get_screen_size()
    cx, cy = w // 2, h // 2
    duration = 800 if args.slow else 300
    px = args.pixels

    for i in range(args.count):
        if args.direction == "down":
            swipe(cx, cy + px // 2, cx, cy - px // 2, duration)
        elif args.direction == "up":
            swipe(cx, cy - px // 2, cx, cy + px // 2, duration)
        elif args.direction == "left":
            swipe(cx + px // 2, cy, cx - px // 2, cy, duration)
        elif args.direction == "right":
            swipe(cx - px // 2, cy, cx + px // 2, cy, duration)

        if i < args.count - 1:
            import time
            time.sleep(0.5)

    print(f"Scrolled {args.direction} {px}px x{args.count}", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
