#!/usr/bin/env python3
"""
mob-annotate: Android UI 元素检测 + 标注
基于 uiautomator dump（结构化数据），不依赖视觉模型，毫秒级完成。

用法:
    mob-annotate                           # dump + 截图 + 标注
    mob-annotate -o screen.jpg -j elems.json
    mob-annotate --no-screenshot           # 只输出元素列表，不截图（最快）
"""
import argparse
import json
import os
import sys
import time

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, SCRIPT_DIR)

from mob_core import dump_ui_tree, take_screenshot, get_screen_size, get_current_app


def annotate_screenshot(image_path, elements, output_path):
    """Draw numbered labels on screenshot at each element's position."""
    from PIL import Image, ImageDraw, ImageFont

    img = Image.open(image_path)
    draw = ImageDraw.Draw(img, "RGBA")

    try:
        font = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf", 18)
    except (OSError, IOError):
        try:
            font = ImageFont.truetype("/System/Library/Fonts/Helvetica.ttc", 18)
        except (OSError, IOError):
            font = ImageFont.load_default()

    for elem in elements:
        x1, y1, x2, y2 = elem.bounds
        color = (255, 0, 0, 160) if elem.clickable else (0, 150, 255, 120)

        # Draw bbox
        draw.rectangle([x1, y1, x2, y2], outline=color, width=2)

        # Draw index label
        label = str(elem.index)
        bbox = font.getbbox(label)
        lw = bbox[2] - bbox[0] + 6
        lh = bbox[3] - bbox[1] + 4
        lx = x1
        ly = max(0, y1 - lh)

        bg_color = (255, 0, 0, 220) if elem.clickable else (0, 100, 255, 200)
        draw.rectangle([lx, ly, lx + lw, ly + lh], fill=bg_color)
        draw.text((lx + 3, ly + 2), label, fill="white", font=font)

    if output_path.lower().endswith(('.jpg', '.jpeg')):
        img.convert("RGB").save(output_path, quality=85)
    else:
        img.save(output_path)


def main():
    ap = argparse.ArgumentParser(description="Android UI element annotator")
    ap.add_argument("-o", "--output", default="mob_annotated.jpg", help="Annotated screenshot path")
    ap.add_argument("-j", "--json", default="mob_elements.json", help="Elements JSON path")
    ap.add_argument("--no-screenshot", action="store_true", help="Skip screenshot, only dump elements (fastest)")
    ap.add_argument("-q", "--quiet", action="store_true")
    args = ap.parse_args()

    t0 = time.time()

    # Dump UI tree
    elements = dump_ui_tree(args.json)
    dump_time = time.time() - t0

    if not args.no_screenshot:
        # Take screenshot
        raw_path = "/tmp/mob_raw_screenshot.png"
        take_screenshot(raw_path)

        # Annotate
        annotate_screenshot(raw_path, elements, args.output)
        if os.path.exists(raw_path):
            os.remove(raw_path)

    elapsed = time.time() - t0

    # Get context
    pkg, act = get_current_app()

    # Check trustworthiness via resource_id ownership
    rid_pkgs = set()
    for e in elements:
        if e.resource_id and ":id/" in e.resource_id:
            rid_pkgs.add(e.resource_id.split(":id/")[0])
    trustworthy = not rid_pkgs or pkg in rid_pkgs or pkg == "unknown"

    # WARNING always prints, even in quiet mode — untrusted data is critical
    if not trustworthy:
        print(f"⚠️  WARNING: UI tree belongs to {rid_pkgs}, not {pkg}. Page is Flutter — data unreliable!", file=sys.stderr)

    if not args.quiet:
        print(f"App: {pkg}", file=sys.stderr)
        print(f"Elements: {len(elements)} ({sum(1 for e in elements if e.clickable)} clickable) in {elapsed:.1f}s", file=sys.stderr)
        if not args.no_screenshot:
            print(f"Annotated: {args.output}", file=sys.stderr)
        print(f"JSON: {args.json}", file=sys.stderr)

    # Print element summary to stdout
    for e in elements:
        label = e.label
        if label:
            inter = "clickable" if e.clickable else "static"
            print(f'[{e.index}] ({e.center[0]},{e.center[1]}) {inter} "{label}"')

    return 0


if __name__ == "__main__":
    sys.exit(main())
