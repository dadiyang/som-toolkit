#!/usr/bin/env python3
"""
som-server: OmniParser 模型常驻服务
避免每次 som-annotate 都重新加载模型（170秒→2秒）。

用法:
    som-server start              # 启动服务（后台运行）
    som-server stop               # 停止服务
    som-server status             # 检查状态
    som-server start --port 8765  # 指定端口
"""
import argparse
import base64
import io
import json
import os
import signal
import sys
import time
import traceback

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, SCRIPT_DIR)

RUNTIME_DIR = os.environ.get("XDG_RUNTIME_DIR", "/tmp")
PID_FILE = os.path.join(RUNTIME_DIR, "som-server.pid")
LOG_PATH = os.path.join(RUNTIME_DIR, "som-server.log")
DEFAULT_PORT = 8765
MAX_BODY_SIZE = 100 * 1024 * 1024  # 100MB


def start_server(port, use_caption=True):
    from http.server import HTTPServer, BaseHTTPRequestHandler
    from som_common import find_omniparser, build_parser_config, bbox_to_elements

    omni_dir, config = build_parser_config(use_caption=use_caption)
    sys.path.insert(0, omni_dir)
    os.environ.setdefault("PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK", "True")

    from util.omniparser import Omniparser

    print("Loading OmniParser model...", flush=True)
    t0 = time.time()
    parser = Omniparser(config)
    print(f"Model loaded in {time.time()-t0:.1f}s. Server ready on port {port}.", flush=True)

    class Handler(BaseHTTPRequestHandler):
        def do_POST(self):
            if self.path == "/parse":
                try:
                    content_length = int(self.headers.get("Content-Length", 0))
                    if content_length <= 0:
                        self._send_error(400, "Missing or invalid Content-Length")
                        return
                    if content_length > MAX_BODY_SIZE:
                        self._send_error(413, f"Request too large ({content_length} bytes, max {MAX_BODY_SIZE})")
                        return

                    body = self.rfile.read(content_length)
                    req = json.loads(body)

                    img_b64 = req["image_base64"]
                    screen_w = req.get("screen_w", 1920)
                    screen_h = req.get("screen_h", 1080)

                    t0 = time.time()
                    labeled_b64, parsed_content = parser.parse(img_b64)
                    elapsed = time.time() - t0

                    elements = bbox_to_elements(parsed_content, screen_w, screen_h)

                    resp_bytes = json.dumps({
                        "labeled_image_base64": labeled_b64,
                        "elements": elements,
                        "elapsed": elapsed,
                    }, ensure_ascii=False).encode()

                    self.send_response(200)
                    self.send_header("Content-Type", "application/json")
                    self.send_header("Content-Length", str(len(resp_bytes)))
                    self.end_headers()
                    self.wfile.write(resp_bytes)

                except (json.JSONDecodeError, KeyError, ValueError) as e:
                    self._send_error(400, f"Bad request: {e}")
                except Exception as e:
                    traceback.print_exc()
                    self._send_error(500, f"Internal error: {e}")

            elif self.path == "/health":
                self._send_ok(b"ok")
            else:
                self.send_response(404)
                self.end_headers()

        def do_GET(self):
            if self.path == "/health":
                self._send_ok(b"ok")
            else:
                self.send_response(404)
                self.end_headers()

        def _send_ok(self, body):
            self.send_response(200)
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        def _send_error(self, code, message):
            resp_bytes = json.dumps({"error": message}).encode()
            self.send_response(code)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(resp_bytes)))
            self.end_headers()
            self.wfile.write(resp_bytes)

        def log_message(self, format, *args):
            sys.stderr.write(f"[som-server] {args[0]}\n")

    try:
        server = HTTPServer(("127.0.0.1", port), Handler)
    except OSError as e:
        print(f"ERROR: Cannot bind port {port}: {e}", file=sys.stderr)
        print(f"Try: som-server start --port {port + 1}", file=sys.stderr)
        sys.exit(1)

    # Save PID
    with open(PID_FILE, "w") as f:
        f.write(str(os.getpid()))

    def cleanup(sig, frame):
        print("\nShutting down...", flush=True)
        if os.path.exists(PID_FILE):
            os.remove(PID_FILE)
        server.shutdown()
        sys.exit(0)

    signal.signal(signal.SIGTERM, cleanup)
    signal.signal(signal.SIGINT, cleanup)

    print(f"Serving on http://127.0.0.1:{port}", flush=True)
    server.serve_forever()


def get_pid():
    if os.path.exists(PID_FILE):
        with open(PID_FILE) as f:
            pid = int(f.read().strip())
        try:
            os.kill(pid, 0)
            return pid
        except OSError:
            os.remove(PID_FILE)
    return None


def main():
    ap = argparse.ArgumentParser(description="SoM OmniParser server")
    ap.add_argument("action", choices=["start", "stop", "status"])
    ap.add_argument("--port", type=int, default=DEFAULT_PORT)
    ap.add_argument("--foreground", "-f", action="store_true", help="Run in foreground")
    ap.add_argument("--no-caption", action="store_true",
                    help="Skip icon caption model. Much faster on CPU.")
    args = ap.parse_args()

    if args.action == "status":
        pid = get_pid()
        if pid:
            print(f"Running (PID {pid})")
        else:
            print("Not running")
        return 0

    elif args.action == "stop":
        pid = get_pid()
        if pid:
            os.kill(pid, signal.SIGTERM)
            print(f"Stopped (PID {pid})")
            time.sleep(1)
            if os.path.exists(PID_FILE):
                os.remove(PID_FILE)
        else:
            print("Not running")
        return 0

    elif args.action == "start":
        pid = get_pid()
        if pid:
            print(f"Already running (PID {pid})")
            return 1

        if args.foreground:
            start_server(args.port, use_caption=not args.no_caption)
        else:
            # Daemonize
            child_pid = os.fork()
            if child_pid == 0:
                os.setsid()
                # Redirect stdout/stderr to log
                log_fd = open(LOG_PATH, "a")
                os.dup2(log_fd.fileno(), sys.stdout.fileno())
                os.dup2(log_fd.fileno(), sys.stderr.fileno())
                log_fd.close()
                start_server(args.port, use_caption=not args.no_caption)
            else:
                print(f"Starting som-server (PID {child_pid})...")
                # Wait a few seconds to detect early crashes
                for _ in range(10):
                    time.sleep(0.5)
                    try:
                        os.kill(child_pid, 0)
                    except OSError:
                        print(f"ERROR: Server process exited. Check log: {LOG_PATH}")
                        return 1
                print(f"Server process running (PID {child_pid}). Model loading may still be in progress.")
                print(f"Log: {LOG_PATH}")
        return 0


if __name__ == "__main__":
    sys.exit(main())
